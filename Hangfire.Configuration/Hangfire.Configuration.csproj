<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>netstandard2.0</TargetFramework>
    <RootNamespace>Hangfire.Configuration</RootNamespace>
    <GenerateAssemblyInfo>false</GenerateAssemblyInfo>
  </PropertyGroup>
  <ItemGroup>
    <None Remove="Install.sql" />
    <None Remove="Pages\script.js" />
    <None Remove="Pages\styles.css" />
  </ItemGroup>
  <ItemGroup>
    <EmbeddedResource Include="Install.sql" />
    <EmbeddedResource Include="Pages\script.js" />
    <EmbeddedResource Include="Pages\styles.css" />
  </ItemGroup>
  <ItemGroup>
    <PackageReference Include="Dapper" Version="1.60.6" />
    <PackageReference Include="Hangfire.AspNetCore" Version="1.7.0" />
    <PackageReference Include="HangFire.SqlServer" Version="1.7.0" />
    <PackageReference Include="Microsoft.AspNetCore.Http.Abstractions" Version="2.2.0" />
  </ItemGroup>
</Project>